# OpenAI API key used by backend workers and services for LLM/image generation.
# Get this from your OpenAI account dashboard.
OPENAI_API_KEY=your-openai-api-key

# PostgreSQL database username for local Docker Compose environment.
POSTGRES_USER=deckgen

# PostgreSQL database password for local Docker Compose environment.
# Use a strong value in your real `.env` file.
POSTGRES_PASSWORD=change-me

# PostgreSQL database name used by application services.
POSTGRES_DB=deckgen

# Clerk backend secret key used by the API to validate/manage auth flows.
CLERK_SECRET_KEY=your-clerk-secret-key

# Clerk publishable key used by frontend clients for authentication setup.
CLERK_PUBLISHABLE_KEY=your-clerk-publishable-key

# Global monthly hard cap in USD for image generation spend across all users.
# Example safe testing value: 5.00
MAX_MONTHLY_BUDGET_USD=5.00